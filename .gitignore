## Visual Studio / .NET — https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/

# VS cache / options
.vs/
Generated\ Files/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml
nunit-*.xml
*.VisualState.xml

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
nuget.exe

# Build artefacts
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
!Directory.Build.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.tlog
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Coverage
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
OpenCover/

# Profiler
*.psess
*.vsp
*.vspx
*.sap
*.e2e

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Rider
*.sln.iml

# JustMock
*.jmconfig

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# VS History / local history
.localhistory/
.vshistory/
.history/

# MSBuild binary log
*.binlog

# Fody
FodyWeavers.xsd

# NVidia Nsight
*.nvuser

# VS Code (keep settings/tasks/launch/extensions)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Windows Installer artefacts from build output
*.cab
*.msi
*.msix
*.msm
*.msp

# Strong-name key (contains private key — do NOT commit)
*.snk

# Release staging folder (created by CD workflow)
release-files/

# Appeon PowerBuilder / SnapDeveloper
/.sd

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
